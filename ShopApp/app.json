{
  "expo": {
    "name": "ShopApp",
    "slug": "shopapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "shopapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sirketadi.shopapp",
      "buildNumber": "1",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSCameraUsageDescription": "Profil fotoğrafı çekmek için kameraya erişim gerekiyor.",
        "NSPhotoLibraryUsageDescription": "Galeriden fotoğraf seçmek için erişim gerekiyor."
      }
    },
    "android": {
      "package": "com.sirketadi.shopapp",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-localization",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "ShopApp, teslimat adresinizi otomatik doldurmak için konumunuza ihtiyaç duyuyor."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Profil fotoğrafı seçmek için galeriye erişim gerekiyor.",
          "cameraPermission": "Profil fotoğrafı çekmek için kameraya erişim gerekiyor."
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "sirket-adi",
          "project": "shopapp"
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/analytics",
      "@react-native-firebase/crashlytics"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "updates": {
      "url": "https://u.expo.dev/00000000-0000-0000-0000-000000000000"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
