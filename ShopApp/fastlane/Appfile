# Gün 52 — Fastlane: uygulama kimliği (app.json'daki bundleIdentifier/package ile aynı olmalı)

app_identifier("com.sirketadi.shopapp")
apple_id(ENV["FASTLANE_APPLE_ID"]) # Apple Developer hesabı e-postası — ortam değişkeninden
team_id(ENV["FASTLANE_TEAM_ID"])   # Apple Developer Team ID
json_key_file(ENV["SUPPLY_JSON_KEY_FILE"]) # Google Play service account key — Android submit için
package_name("com.sirketadi.shopapp")
